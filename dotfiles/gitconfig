[user]
    name = Dru Sellers
    email = dru@drusellers.com
[core]
    editor = code --wait
    autocrlf = false
    pager = delta
[delta]
    plus-style = "normal #012800"
    minus-style = "normal #340001"
    syntax-theme = Monokai Extended
[diff]
    tool = bc3
    renames = copies
[difftool]
    prompt = false
[difftool "bc3"]
    path = /usr/local/bin/bcomp
[merge]
    tool = bc3
[mergetool "bc3"]
    path = /usr/local/bin/bcomp
    trustExitCode = true
[alias]
    st = status
    c = commit -m
    aa = add -A
    fa = !git fetch --all --prune
    co = checkout
    pu = clean -dfx
    new = "!f() { git checkout -b \"dds/$1\"; }; f"
    pnb = push -u origin HEAD
    pf = push --force-with-lease
    pushr = push --force-with-lease origin main:release
    rom = rebase origin/main
    rum = rebase upstream/main
    rod = rebase origin/develop
    rud = rebase upstream/develop
    graph = log --graph --decorate --pretty=oneline --abbrev-commit
    diffdir = difftool --dir-diff --tool=bc3 --no-prompt
[log]
    date = relative
[branch]
    autosetupmerge = true
[mergetool]
    keepBackup = false
    prompt = false
[push]
    default = simple
[credential]
    helper = store
[rebase]
    autosquash = true
    autoStash = true
    updateRefs = true
[fetch]
    prune = true
[pager]
    branch = cat
[rerere]
    enabled = true
[pull]
    ff = only
    rebase = true
[interactive]
    diffFilter = delta --color-only
[init]
	defaultBranch = main
